# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# Your API key — leave empty to run in deterministic fallback mode
LLM_API_KEY=

# Model to use
# OpenAI examples: gpt-4.1-mini, gpt-4o, gpt-4-turbo
# Anthropic examples: claude-sonnet-4-6, claude-haiku-4-5-20251001
LLM_MODEL=gpt-4.1-mini

# SQLite database path (relative to project root)
DATABASE_PATH=evaluation_runs.db

# LLM request timeout in seconds
LLM_TIMEOUT_SECONDS=20
